# OpenAI
OPENAI_API_KEY=sk-...

# PostgreSQL (docker-compose)
POSTGRES_PASSWORD=admin1234
DATABASE_URL=postgresql+psycopg2://admin:admin1234@localhost:5432/realestate

# 기존 realestate/ 데이터 경로 (migrate_db.py 실행 및 가격 예측 모델 로드에 필요)
SQLITE_DB_PATH=/path/to/realestate/data/processed/realestate.db
MODEL_PATH=/path/to/realestate/data/models/price_model_trade_lgbm_complex.pkl
RENT_MODEL_PATH=/path/to/realestate/data/models/price_model_rent_lgbm_complex.pkl

# Kakao (지오코딩)
KAKAO_API_KEY=...

# Langfuse (모니터링) — https://cloud.langfuse.com 에서 발급
LANGFUSE_SECRET_KEY="sk..."
LANGFUSE_PUBLIC_KEY="pk..."
LANGFUSE_HOST="https://us.cloud.langfuse.com"
# 앱 설정
LOG_LEVEL=INFO

# Tavily Search (최신 뉴스·GTX 등 웹 검색) — https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Frontend (frontend/.env.local) ───────────────────────────────────────────
# Kakao Maps JS API 키 (https://developers.kakao.com)
NEXT_PUBLIC_KAKAO_MAP_KEY=...
# FastAPI 백엔드 URL (Vercel 배포 시 실제 서버 URL로 변경)
NEXT_PUBLIC_API_BASE=http://localhost:8000
API_BASE=http://localhost:8000